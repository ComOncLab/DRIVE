tsi_markers <- TCellSI::markers
View(tsi_markers)
library(UCell)
scores <- ScoreSignatures_UCell(GetAssayData(object = t_obj, slot = "counts"),
features=tsi_markers)
View(scores)
t_meta <- t_obj@meta.data
View(t_meta)
scores <- as.data.frame(scores)
scores$cell_id <- rownames(scores)
dt <- left_join(t_meta %>% select(cell_id, sample_name, sample_type), scores)
View(dt)
library(ggpubr)
colnames(dt)
ggboxplot(dt,x="sample_type",y="Cytotoxicity_UCell")
ggboxplot(dt,x="sample_type",y="Proliferation_UCell")
library(AUCell)
scores <- AUCell_run(GetAssayData(object = t_obj, slot = "counts"), tsi_markers)
View(scores)
scores <- getAUC(scores) %>% t() %>% as.data.frame()
View(scores)
t_meta <- t_obj@meta.data
scores <- as.data.frame(scores)
scores$cell_id <- rownames(scores)
dt <- left_join(t_meta %>% select(cell_id, sample_name, sample_type), scores)
colnames(dt)
