library(dplyr)
library(Seurat)
sample_meta <- readxl::read_xlsx("data/CELL_metadata.xlsx",sheet = 2)
tn <- sample_meta %>% filter(`Treatement Timepoint` == "TN")
osi <- sample_meta %>% filter(Treatment == "osimertinib") %>%
filter(`Treatement Timepoint` != "TN")
load("data/IM01_Immune_Seurat_object_nodups-006.RData")
new_obj <- UpdateSeuratObject(tiss_immune)
new_obj <- subset(new_obj, subset = sample_name %in% c(tn$`Sample Name`,osi$`Sample Name`))
new_obj$sample_type <- case_when(
new_obj$sample_name %in% tn$`Sample Name` ~ "Naive",
new_obj$sample_name %in% osi$`Sample Name` ~ "Osimertinib Treatment"
)
obj_meta <- new_obj@meta.data
obj_meta <- obj_meta %>%
select(sample_name, cell_id, immune_subtype_annotation, sample_type)
View(obj_meta)
##
t_cells <- rownames(obj_meta)[which(obj_meta$immune_subtype_annotation == "T-cells")]
unique(obj_meta$sample_name) %>% length()
t_obj <- subset(new_obj, cells =  t_cells)
t_obj
BiocManager::install("UCell")
TCellSI::markers
