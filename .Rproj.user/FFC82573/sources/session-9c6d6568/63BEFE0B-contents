library(Seurat)
library(SeuratDisk)
library(loomR)
loom_obj <- connect(filename = "~/hypoxia_model/perturbation/pcd_obj_comb.loom",
                    mode = "r",skip.validate = T)
seurat_obj <- LoadLoom("~/hypoxia_model/perturbation/pcd_obj_comb.loom",features = "ensembl_id")

# 获取基因的表达值
gene_a_expression <- GetAssayData(object = seurat_obj, slot = "data")["ENSG00000160688", ]
# 创建分组
high_cells <- colnames(seurat_obj)[gene_a_expression > 1]
low_cells <- colnames(seurat_obj)[(gene_a_expression <= 1) & (gene_a_expression != 0)]
# 拆分Seurat对象
seurat_high <- subset(seurat_obj, cells = high_cells)
seurat_low <- subset(seurat_obj, cells = low_cells)

SaveLoom(seurat_high,
         filename = "~/hypoxia_model/perturbation/flad1_high/flad1_high.loom",
         gene_col_name = "ensembl_id",
         overwrite = TRUE)
SaveLoom(seurat_low,
         filename = "~/hypoxia_model/perturbation/flad1_low/flad1_low.loom",
         gene_col_name = "ensembl_id",
         overwrite = TRUE)

lfile <- loomR::connect(filename = "~/hypoxia_model/perturbation/flad1_low/flad1_low.loom", 
                        mode = "r+",skip.validate = T)
lfile$add.col.attribute(list(n_counts = lfile$col.attrs$nCount_RNA[]), 
                        overwrite = TRUE)
lfile$add.col.attribute(list(individual = 1:ncol(seurat_low)), 
                        overwrite = TRUE)
lfile[["row_attrs"]]
lfile[["col_attrs"]]
lfile$close_all()

