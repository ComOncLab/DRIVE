tt <- list.files("~/hypoxia_model/perturbation/hypoxia_random/",recursive = T,pattern = ".csv",full.names = T)
tt_res <- lapply(tt,
                 function(x){
                   dt <- read.csv(x)
                   dt$id <- gsub(".+//","",x) %>% gsub("/.+","",.)
                   return(dt)
                 })
tt_res <- bind_rows(tt_res)
gene_mat <- data.frame(
  FLAD1 = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "FLAD1")],
  NDUFB9 = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "NDUFB9")],
  NDUFA7 = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "NDUFA7")],
  SDHA = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "SDHA")],
  SDHB = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "SDHB")],
  SDHC = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "SDHC")],
  SDHD = tt_res$Shift_to_goal_end[which(tt_res$Gene_name == "SDHD")]
)
library(ggcorrplot)
rcorr_matrix <- cor(as.matrix(gene_mat))
cor_p <- cor_pmat(gene_mat)
p1 <- ggcorrplot::ggcorrplot(rcorr_matrix, p.mat = cor_p,type = "lower")

####随便选6个基因算相关性
tt_summ <- tt_res %>% group_by(Gene_name) %>% summarise(counts = n()) %>% ungroup() %>% 
  filter(counts == 16)
all_genes <- tt_summ$Gene_name
res <- vector()
for (i in 1:100){
  sampled_gene <- sample(all_genes, 6, replace = F)
  sampled_gene <- c("FLAD1",sampled_gene)
  tmp_dt <- tt_res %>% filter(Gene_name %in% sampled_gene) %>% 
    select(Gene_name, Shift_to_goal_end) %>% 
    group_by(Gene_name) %>%
    mutate(id = row_number()) %>%
    ungroup() %>% tidyr::pivot_wider(names_from = Gene_name, values_from = Shift_to_goal_end) %>% 
    select(-id)
  tmp_cor <- cor(as.matrix(tmp_dt))
  res <- append(res, median(tmp_cor[lower.tri(tmp_cor)]))
}

library(ggplot2)
library(ggpubr)
res <- data.frame(lower_cor_mat = res)
p2 <- ggdensity(res,x="lower_cor_mat",xlab = "Median of the lower triangle of the correlation matrix")+
  geom_vline(xintercept = median(rcorr_matrix[lower.tri(rcorr_matrix)]), 
             color = "red", 
             linetype = "dashed", 
             linewidth = 1)

library(patchwork)
p1+p2

