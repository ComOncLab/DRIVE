all_files <- list.files("~/hypoxia_model/perturbation/patients/",recursive = T, pattern = "csv")
res <- sapply(all_files,
              function(x){
                tt <- read.csv(paste0("~/hypoxia_model/perturbation/patients/",x))
                tt$sample <- gsub("/.+","",x)
                return(tt)
              },simplify = F)
res <- bind_rows(res)
res <- res %>% 
  select(sample, Gene_name, Shift_to_goal_end) %>% 
  filter(Gene_name %in% c("FLAD1","NDUFB9","NDUFA7","SDHA","SDHB","SDHC","SDHD"))
dt <- res %>% 
  tidyr::pivot_wider(names_from = Gene_name, values_from = Shift_to_goal_end)

hypo <- readRDS("~/hypoxia_model/buffa_score.rds")
hypo <- hypo %>% 
  mutate(type = ifelse(buffa_score > 0,"hypo","no_hypo"))

res <- res %>% 
  mutate(sample = gsub("_","-",sample))
dt1 <- res %>% filter(sample %in% hypo$sample[which(hypo$type == "hypo")])
dt2 <- res %>% filter(sample %in% hypo$sample[which(hypo$type == "no_hypo")])
dt1 <- dt1 %>% 
  tidyr::pivot_wider(names_from = Gene_name, values_from = Shift_to_goal_end)
dt2 <- dt2 %>% 
  tidyr::pivot_wider(names_from = Gene_name, values_from = Shift_to_goal_end)

library(ggcorrplot)
cor1 <- cor(as.matrix(dt1[,2:8]),use = "pairwise.complete.obs")
p_1 <- cor_pmat(dt1[,2:8])
cor2 <- cor(as.matrix(dt2[,2:8]),use = "pairwise.complete.obs")
p_2 <- cor_pmat(dt2[,2:8])
cor2 <- cor2[rownames(cor1),colnames(cor1)]
p_2 <- p_2[rownames(p_1),colnames(p_1)]

p1 <- ggcorrplot::ggcorrplot(cor1,type = "lower")
p2 <- ggcorrplot::ggcorrplot(cor2,type = "lower")
library(patchwork)
p1+p2

dt3 <- data.frame(
  hypo_cor = cor1[lower.tri(cor1)],
  no_hypo_cor = cor2[lower.tri(cor2)],
  id = 1:length(cor1[lower.tri(cor1)])
)
ggpaired(dt3, cond1 = "hypo_cor", cond2 = "no_hypo_cor",
         fill = "condition")+
  stat_compare_means(paired = T)+
